# Copiază acest fișier în `.env.local` și completează valorile reale.
# `.env.local` e ignorat de git — valorile reale nu ajung niciodată în repo.
# În producție, aceleași chei se pun în Netlify → Site settings → Environment variables.

# ─── Firebase (client, public prin design) ──────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Google Analytics 4 (ID public) ─────────────────────────────────────
NEXT_PUBLIC_GA_ID=

# ─── Site ───────────────────────────────────────────────────────────────
# Adresa canonică (sitemap, canonical, OpenGraph).
NEXT_PUBLIC_SITE_URL=https://careval.ro

# ─── NETOPIA Payments (API v2) ──────────────────────────────────────────
# Sandbox:   https://secure.sandbox.netopia-payments.com
# Producție: https://secure.netopia-payments.com
NETOPIA_BASE_URL=https://secure.sandbox.netopia-payments.com
# Semnătura punctului de vânzare: Puncte de vânzare → ⋮ → Setări tehnice.
# ATENȚIE: sandbox și producție au semnături DIFERITE. Nu le amesteca.
NETOPIA_POS_SIGNATURE=
# Cheia API: iconița contului (dreapta sus) → Securitate → Generează cheie.
# SECRET. Fără prefix NEXT_PUBLIC_, ca să rămână doar pe server.
NETOPIA_API_KEY=

# ─── SmartBill (facturare automată) ─────────────────────────────────────
# Întrerupător de siguranță: cu `false` nu se emite NICIO factură, doar se
# logează ce s-ar fi trimis. Se pune pe `true` abia după ce plata e verificată.
SMARTBILL_ENABLED=false
SMARTBILL_USER=
SMARTBILL_TOKEN=
SMARTBILL_CIF=
# Serie distinctă pentru facturile emise automat, ca să fie ușor de identificat.
SMARTBILL_SERIES=
